<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Zaid Digital — Premium Webdesign für lokale Unternehmen</title>
  <meta name="description" content="Zaid Digital gestaltet hochwertige, individuelle Websites für Friseure, Elektriker, Restaurants und lokale Unternehmen in Hamm und Umgebung. Webdesign, das nach Wert aussieht — und Kunden bringt.">
  <meta name="theme-color" content="#08080a">
  <link rel="icon" href="assets/logo-mark.svg" type="image/svg+xml">
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Zaid Digital — Premium Webdesign für lokale Unternehmen">
  <meta property="og:description" content="Hochwertige, individuelle Websites für Friseure, Elektriker, Restaurants & lokale Betriebe. Webdesign, das nach Wert aussieht.">
  <meta property="og:locale" content="de_DE">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="stylesheet" href="fonts.css">
  <link rel="stylesheet" href="style.css">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Zaid Digital",
    "description": "Premium Webdesign für lokale Unternehmen — individuelle, hochwertige Websites für Friseure, Elektriker, Restaurants und Handwerksbetriebe.",
    "founder": "Zaid Sinan",
    "email": "info@zaiddigital.de",
    "telephone": "+49-179-4741210",
    "areaServed": "Hamm und Umgebung",
    "priceRange": "€€",
    "address": { "@type": "PostalAddress", "addressLocality": "Hamm", "addressCountry": "DE" },
    "knowsAbout": ["Webdesign", "Webentwicklung", "SEO", "Responsive Design"]
  }
  </script>
</head>
<body>

  <!-- Scroll Progress Bar -->
  <div class="progress-bar"><div class="progress-bar__fill" id="progressFill"></div></div>

  <!-- Fixed Rotating Globe (travels on scroll) -->
  <div class="globe-layer" id="globeLayer">
    <div class="globe">
      <span class="globe__star" style="left:-20px;top:10px;animation-duration:3s"></span>
      <span class="globe__star" style="left:-40px;top:40px;animation-duration:2s"></span>
      <span class="globe__star" style="left:270px;top:90px;animation-duration:4s"></span>
      <span class="globe__star" style="left:210px;top:280px;animation-duration:3s"></span>
      <span class="globe__star" style="left:50px;top:270px;animation-duration:1.5s"></span>
      <span class="globe__star" style="left:260px;top:-40px;animation-duration:4s"></span>
      <span class="globe__star" style="left:290px;top:60px;animation-duration:2s"></span>
    </div>
  </div>

  <!-- Section Navigation Dots -->
  <nav class="dots" id="dots" aria-label="Abschnitte"></nav>

  <!-- Header -->
  <header class="header" id="header">
    <div class="header__inner">
      <a href="#hero" class="brand">
        <img class="brand__logo" src="assets/logo-mark.svg" alt="" width="44" height="44">
        <span class="brand__name">Zaid&nbsp;Digital</span>
      </a>
      <nav class="header__nav">
        <a href="#leistungen">Leistungen</a>
        <a href="#portfolio">Portfolio</a>
        <a href="#preise">Preise</a>
        <a href="#ueber">Über mich</a>
        <a href="#kontakt">Kontakt</a>
      </nav>
      <div class="header__actions">
        <a href="tel:+491794741210" class="btn btn--ghost btn--sm">Anrufen</a>
        <a href="#kontakt" class="btn btn--primary btn--sm">Projekt starten</a>
      </div>
      <button class="burger" id="burger" aria-label="Menü"><span></span><span></span><span></span></button>
    </div>
  </header>

  <!-- Mobile Menu -->
  <div class="mobile" id="mobile">
    <a href="#leistungen">Leistungen</a>
    <a href="#portfolio">Portfolio</a>
    <a href="#preise">Preise</a>
    <a href="#ueber">Über mich</a>
    <a href="#kontakt">Kontakt</a>
    <a href="#kontakt" class="btn btn--primary">Projekt starten</a>
  </div>

  <main>

    <!-- ===== HERO (globe right) ===== -->
    <section class="snap" id="hero" data-globe="0">
      <div class="shapes" aria-hidden="true">
        <span class="shape shape--1"></span>
        <span class="shape shape--2"></span>
        <span class="shape shape--3"></span>
        <span class="shape shape--4"></span>
      </div>
      <div class="hero">
        <div class="reveal">
          <span class="pill"><span class="pill__dot"></span> Premium Webdesign-Studio · Hamm &amp; bundesweit</span>
        </div>
        <h1 class="hero__title reveal">
          Von Idee zur Website.<br>
          <span class="serif-em">48 Stunden max.</span>
        </h1>
        <p class="hero__lead reveal">
          Keine Wartezeiten. Kein Baukasten-Look.
        </p>
        <div class="hero__cta reveal">
          <a href="#portfolio" class="btn btn--primary btn--lg">Meine Arbeit ansehen
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="#kontakt" class="btn btn--outline btn--lg">Kostenlos beraten lassen</a>
        </div>
        <div class="hero__meta reveal">
          <span><span class="hero__meta-dot"></span> Festpreis &amp; transparent</span>
          <span><span class="hero__meta-dot"></span> In 48 Std. online</span>
          <span><span class="hero__meta-dot"></span> DSGVO-konform</span>
        </div>
      </div>
    </section>

    <!-- ===== STORY: Branchen (globe center, subtle) ===== -->
    <section class="snap snap--center" id="branchen" data-globe="1">
      <div class="story">
        <span class="kicker reveal">Für jede Branche</span>
        <h2 class="story__title reveal">Eine Website,<br>die zu deinem<br><span class="serif-em">Handwerk passt.</span></h2>
        <p class="story__lead reveal">
          Ob Schere, Schraubenzieher oder Pfanne — jede Branche hat eigene Kunden,
          eigene Bedürfnisse und eine eigene Sprache. Genau danach baue ich deine Website.
        </p>
        <div class="chips reveal">
          <span class="chip">Friseure</span>
          <span class="chip">Elektriker</span>
          <span class="chip">Handwerker</span>
          <span class="chip">Restaurants</span>
          <span class="chip">Cafés</span>
          <span class="chip">Kosmetikstudios</span>
          <span class="chip">Fitnessstudios</span>
        </div>
      </div>
    </section>

    <!-- ===== LEISTUNGEN ===== -->
    <section class="block" id="leistungen" data-globe="fade">
      <div class="shell">
        <div class="head reveal">
          <span class="kicker">Leistungen</span>
          <h2 class="head__title">Alles aus einer Hand</h2>
          <p class="head__lead">Von der ersten Idee bis zur fertigen Website — du musst dich um nichts Technisches kümmern.</p>
        </div>
        <div class="cards">
          <article class="card reveal">
            <div class="card__glow"></div>
            <div class="card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r="2.5"/><circle cx="6.5" cy="12.5" r="2.5"/><circle cx="16.5" cy="15.5" r="2.5"/><path d="M12 2a10 10 0 100 20"/></svg>
            </div>
            <h3>Individuelles Webdesign</h3>
            <p>Ein Design, das zu deiner Marke passt und Vertrauen bei deinen Kunden aufbaut — kein Baukasten von der Stange.</p>
          </article>
          <article class="card reveal">
            <div class="card__glow"></div>
            <div class="card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
            <h3>Webentwicklung</h3>
            <p>Schnelle, saubere und responsive Umsetzung. Deine Seite sieht auf Handy, Tablet und Desktop perfekt aus.</p>
          </article>
          <article class="card reveal">
            <div class="card__glow"></div>
            <div class="card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
            </div>
            <h3>SEO &amp; Google</h3>
            <p>Damit dein Geschäft lokal gefunden wird — Google-Maps-Eintrag, Keywords und technische Optimierung inklusive.</p>
          </article>
          <article class="card reveal">
            <div class="card__glow"></div>
            <div class="card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9z"/></svg>
            </div>
            <h3>Performance</h3>
            <p>Blitzschnelle Ladezeiten für bessere Rankings und zufriedene Besucher, die nicht abspringen.</p>
          </article>
          <article class="card reveal">
            <div class="card__glow"></div>
            <div class="card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Rechtssicherheit</h3>
            <p>Impressum, DSGVO-Datenschutz und Cookie-Hinweis — damit du rechtlich auf der sicheren Seite bist.</p>
          </article>
          <article class="card reveal">
            <div class="card__glow"></div>
            <div class="card__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            </div>
            <h3>Persönlicher Support</h3>
            <p>Auch nach dem Launch bin ich für dich da — Änderungen, Updates und Fragen werden schnell erledigt.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ===== PORTFOLIO BENTO ===== -->
    <section class="block block--alt" id="portfolio">
      <div class="shell">
        <div class="head reveal">
          <span class="kicker">Portfolio</span>
          <h2 class="head__title">Beispiele &amp; Varianten</h2>
          <p class="head__lead">So können Websites für verschiedene Branchen aussehen — jede mit den Funktionen, die wirklich gebraucht werden.</p>
        </div>
        <div class="bento">
          <article class="bento__item bento__item--big reveal" style="--tint:rgba(201,169,106,.12)">
            <a class="bento__preview" href="demos/friseur.html?v=3" target="_blank" rel="noopener" aria-label="Demo Salon Aurelia öffnen">
              <iframe src="demos/friseur.html?v=3" loading="lazy" scrolling="no" tabindex="-1" title="Vorschau Salon Aurelia"></iframe>
              <span class="bento__preview-hint">Demo öffnen ↗</span>
            </a>
            <div class="bento__label">
              <span class="bento__tag">Friseur &amp; Beauty</span>
              <h3>Salon-Website</h3>
              <p>Elegantes Design mit Online-Terminbuchung, Galerie, Team &amp; Preisliste.</p>
              <ul><li>Online-Termine</li><li>Bildergalerie</li><li>Google Maps</li></ul>
              <a class="bento__link" href="demos/friseur.html?v=3" target="_blank" rel="noopener">Live-Demo ansehen
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
              </a>
            </div>
          </article>

          <article class="bento__item reveal" style="--tint:rgba(120,150,220,.09)">
            <a class="bento__preview" href="demos/elektriker.html?v=3" target="_blank" rel="noopener" aria-label="Demo Elektro Bauer öffnen">
              <iframe src="demos/elektriker.html?v=3" loading="lazy" scrolling="no" tabindex="-1" title="Vorschau Elektro Bauer"></iframe>
              <span class="bento__preview-hint">Demo öffnen ↗</span>
            </a>
            <div class="bento__label">
              <span class="bento__tag">Elektro &amp; Handwerk</span>
              <h3>Handwerker-Website</h3>
              <p>Mit Notdienst-Button &amp; Leistungsübersicht.</p>
              <a class="bento__link" href="demos/elektriker.html?v=3" target="_blank" rel="noopener">Live-Demo ansehen
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
              </a>
            </div>
          </article>

          <article class="bento__item reveal" style="--tint:rgba(120,180,140,.09)">
            <a class="bento__preview" href="demos/restaurant.html?v=3" target="_blank" rel="noopener" aria-label="Demo Trattoria Verde öffnen">
              <iframe src="demos/restaurant.html?v=3" loading="lazy" scrolling="no" tabindex="-1" title="Vorschau Trattoria Verde"></iframe>
              <span class="bento__preview-hint">Demo öffnen ↗</span>
            </a>
            <div class="bento__label">
              <span class="bento__tag">Gastronomie</span>
              <h3>Restaurant-Website</h3>
              <p>Speisekarte, Reservierung &amp; Atmosphäre.</p>
              <a class="bento__link" href="demos/restaurant.html?v=3" target="_blank" rel="noopener">Live-Demo ansehen
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
              </a>
            </div>
          </article>

          <article class="bento__item bento__item--wide reveal" style="--tint:rgba(201,169,106,.10)">
            <div class="bento__mock">
              <svg class="variant-art" viewBox="0 0 520 300" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Individuelle Website konfigurieren">
                <defs>
                  <linearGradient id="va_g" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#e7cd92"/><stop offset="1" stop-color="#c9a96a"/></linearGradient>
                </defs>
                <rect x="14" y="16" width="492" height="268" rx="18" fill="#15120c" stroke="rgba(201,169,106,.3)"/>
                <line x1="14" y1="58" x2="506" y2="58" stroke="rgba(255,255,255,.08)"/>
                <circle cx="40" cy="37" r="4.5" fill="#544b32"/><circle cx="58" cy="37" r="4.5" fill="#544b32"/><circle cx="76" cy="37" r="4.5" fill="#544b32"/>
                <rect x="40" y="84" width="206" height="120" rx="12" fill="url(#va_g)" opacity=".92"/>
                <rect x="64" y="120" width="120" height="12" rx="6" fill="#15120c" opacity=".5"/>
                <rect x="64" y="142" width="80" height="10" rx="5" fill="#15120c" opacity=".35"/>
                <rect x="64" y="170" width="70" height="20" rx="10" fill="#15120c" opacity=".6"/>
                <rect x="270" y="86" width="196" height="14" rx="7" fill="rgba(255,255,255,.14)"/>
                <rect x="270" y="112" width="150" height="12" rx="6" fill="rgba(255,255,255,.09)"/>
                <rect x="270" y="148" width="92" height="34" rx="17" fill="none" stroke="rgba(255,255,255,.16)"/>
                <rect x="372" y="148" width="92" height="34" rx="17" fill="url(#va_g)"/>
                <rect x="270" y="206" width="60" height="40" rx="10" fill="rgba(255,255,255,.06)"/>
                <rect x="340" y="206" width="60" height="40" rx="10" fill="rgba(255,255,255,.06)"/>
                <rect x="410" y="206" width="56" height="40" rx="10" fill="rgba(255,255,255,.06)"/>
                <rect x="40" y="222" width="160" height="40" rx="10" fill="rgba(255,255,255,.05)"/>
                <g class="va_spark">
                  <path d="M470 40 l5 14 14 5 -14 5 -5 14 -5 -14 -14 -5 14 -5 z" fill="url(#va_g)"/>
                </g>
              </svg>
            </div>
            <div class="bento__label">
              <span class="bento__tag">Individuell</span>
              <h3>Deine eigene Variante</h3>
              <p>Andere Branche oder besondere Wünsche? Beantworte 4 kurze Fragen — und finde in 30 Sekunden die passende Richtung für deine Website.</p>
              <button type="button" class="bento__link" id="openFinder">Website-Finder starten
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </button>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ===== PROZESS ===== -->
    <section class="block" id="prozess">
      <div class="shell">
        <div class="head reveal">
          <span class="kicker">Ablauf</span>
          <h2 class="head__title">In 4 Schritten online</h2>
        </div>
        <div class="flow">
          <div class="flow__step reveal">
            <div class="flow__icon">💬</div>
            <div class="flow__body">
              <div class="flow__top"><h3>Erstgespräch</h3></div>
              <p>In einem unverbindlichen Gespräch lernen wir dein Unternehmen, deine Ziele und deine Zielgruppe kennen.</p>
            </div>
          </div>
          <div class="flow__step reveal">
            <div class="flow__icon">🖌️</div>
            <div class="flow__body">
              <div class="flow__top"><h3>Konzept &amp; Design</h3></div>
              <p>Wir entwickeln ein individuelles Designkonzept, das zu deiner Branche und deiner Marke passt — abgestimmt auf dein Feedback.</p>
            </div>
          </div>
          <div class="flow__step reveal">
            <div class="flow__icon">⚡</div>
            <div class="flow__body">
              <div class="flow__top"><h3>Umsetzung</h3></div>
              <p>Deine Website wird professionell umgesetzt — leistungsstark, auf allen Endgeräten optimal dargestellt und für Suchmaschinen optimiert.</p>
            </div>
          </div>
          <div class="flow__step reveal">
            <div class="flow__icon">🚀</div>
            <div class="flow__body">
              <div class="flow__top"><h3>Veröffentlichung</h3></div>
              <p>Deine Website geht online. Auch danach stehen wir dir für Pflege, Aktualisierungen und Anpassungen zuverlässig zur Seite.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PREISE ===== -->
    <section class="block" id="preise">
      <div class="shell">
        <div class="head reveal">
          <span class="kicker">Preise</span>
          <h2 class="head__title">Faire Preise, planbar</h2>
          <p class="head__lead">Kleine Erstzahlung, danach ein fester monatlicher Betrag — du musst nicht alles auf einmal zahlen. Der genaue Umfang wird individuell auf Anfrage abgestimmt.</p>
        </div>

        <div class="roi reveal">
          <span class="roi__big">ab&nbsp;~3&nbsp;€</span>
          <span class="roi__txt">pro Tag — und schon <strong>eine einzige neue Kundin im Monat</strong> bezahlt deine komplette Website.</span>
        </div>

        <div class="tiers">
          <article class="tier reveal">
            <h3 class="tier__name">Start</h3>
            <p class="tier__desc">Der professionelle Einstieg</p>
            <div class="tier__price"><span class="tier__amount">99</span><sup>€</sup><span class="tier__per">/ Monat</span></div>
            <p class="tier__setup">+ einmalig 500&nbsp;€ Erstzahlung · 12 Monate Laufzeit</p>
            <p class="tier__highlight">Perfekt, um online endlich seriös aufzutreten.</p>
            <ul class="tier__list">
              <li>Professionelle One-Page-Website</li>
              <li>Individuelles Design für deine Marke</li>
              <li>Perfekt auf Handy &amp; Tablet</li>
              <li>Kontaktformular &amp; Google Maps</li>
              <li>Bei Google auffindbar (SEO-Basis)</li>
              <li>Hosting, Wartung &amp; Updates inklusive</li>
              <li>Impressum &amp; DSGVO rechtssicher</li>
            </ul>
            <a href="#kontakt" class="btn btn--outline btn--block">Anfragen</a>
          </article>

          <article class="tier tier--featured reveal">
            <span class="tier__badge">★ Beliebteste Wahl</span>
            <h3 class="tier__name">Premium</h3>
            <p class="tier__desc">Für Betriebe, die aktiv Kunden gewinnen wollen</p>
            <div class="tier__price"><span class="tier__amount">149</span><sup>€</sup><span class="tier__per">/ Monat</span></div>
            <p class="tier__setup">+ einmalig 900&nbsp;€ Erstzahlung · 12 Monate Laufzeit</p>
            <p class="tier__highlight tier__highlight--gold">Für nur 50&nbsp;€ mehr im Monat holt deine Seite aktiv neue Kunden.</p>
            <ul class="tier__list">
              <li>Mehrseitige Website (bis zu 5 Seiten)</li>
              <li><strong>Online-Terminbuchung / Tischreservierung</strong></li>
              <li>Foto-Galerie deiner Arbeiten</li>
              <li>Stärkere Google-Platzierung (erweiterte SEO)</li>
              <li>Echte Kundenbewertungen eingebunden</li>
              <li>Schnellerer, bevorzugter Support</li>
              <li>Hosting, Wartung &amp; Rechtssicherheit inklusive</li>
            </ul>
            <a href="#kontakt" class="btn btn--primary btn--block">Anfragen</a>
          </article>

          <article class="tier reveal">
            <h3 class="tier__name">Komplett</h3>
            <p class="tier__desc">Rundum-sorglos für maximales Wachstum</p>
            <div class="tier__price"><span class="tier__amount">250</span><sup>€</sup><span class="tier__per">/ Monat</span></div>
            <p class="tier__setup">+ einmalig 1.500&nbsp;€ Erstzahlung · 12 Monate Laufzeit</p>
            <p class="tier__highlight tier__highlight--gold">Solange du dabei bist, baue ich dir Websites — <strong>auch für jedes weitere Unternehmen, das du hast.</strong></p>
            <ul class="tier__list">
              <li><strong>Websites für all deine Unternehmen</strong> — solange das Abo läuft</li>
              <li>Unbegrenzte Unterseiten</li>
              <li>Maßgeschneidertes Premium-Design</li>
              <li>Laufende SEO-Betreuung – Monat für Monat</li>
              <li>Monats-Report: Besucher &amp; Anfragen</li>
              <li>Priorität bei allen Änderungswünschen</li>
              <li>Persönlicher Ansprechpartner für alles</li>
            </ul>
            <a href="#kontakt" class="btn btn--outline btn--block">Anfragen</a>
          </article>
        </div>
        <p class="plans__foot reveal">Alle Pakete laufen über einen <strong>12-Monats-Vertrag</strong> · individuell anpassbar · faire Festpreise. <a href="#kontakt">Schreib mir</a> für ein persönliches Angebot.</p>
      </div>
    </section>

    <!-- ===== ÜBER MICH ===== -->
    <section class="block block--alt" id="ueber">
      <div class="shell">
        <div class="about">
          <div class="about__text reveal">
            <span class="kicker">Über mich</span>
            <h2 class="head__title" style="text-align:left">Hi, ich bin Zaid.</h2>
            <p>Ich baue Websites für lokale Unternehmen, die online bisher zu kurz kommen. Viele Friseure, Handwerker und Gastronomen haben großartige Betriebe — aber eine Website, die nicht überzeugt. Genau das ändere ich.</p>
            <p>Mein Anspruch: ein Auftritt, der hochwertig aussieht, schnell lädt und neue Kunden bringt. Persönlich, unkompliziert und zu fairen Festpreisen.</p>
            <div class="about__stats">
              <div><strong data-count="13">0</strong><span>+ Projekte</span></div>
              <div><strong data-count="48">0</strong><span>h Ø Lieferung</span></div>
              <div><strong data-count="100">0</strong><span>% Mobiloptimiert</span></div>
            </div>
          </div>
          <div class="about__visual reveal">
            <div class="about__card">
              <div class="about__frame">
                <img class="about__photo" src="assets/zaid.jpg" alt="Zaid Sinan — Gründer von Zaid Digital" loading="lazy" decoding="async"
                     onerror="this.style.display='none';document.getElementById('zfallback').style.display='grid'">
                <div class="about__avatar" id="zfallback" style="display:none">Z</div>
              </div>
              <div class="about__quote">„Eine gute Website ist dein bester Mitarbeiter — sie arbeitet 24/7 und macht nie Pause."</div>
              <div class="about__sign">— Zaid Sinan, Gründer von Zaid Digital</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== KONTAKT ===== -->
    <section class="block" id="kontakt">
      <div class="shell">
        <div class="contact">
          <div class="contact__intro reveal">
            <span class="kicker">Kontakt</span>
            <h2 class="head__title" style="text-align:left">Lass uns dein Projekt starten.</h2>
            <p>Erzähl mir kurz von deinem Business — die Erstberatung ist immer kostenlos und unverbindlich.</p>
            <ul class="contact__list">
              <li><a href="mailto:info@zaiddigital.de" style="display:flex;align-items:center;gap:14px;color:inherit"><span class="contact__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></span><div><b>E-Mail</b><span>info@zaiddigital.de</span></div></a></li>
              <li><a href="tel:+491794741210" style="display:flex;align-items:center;gap:14px;color:inherit"><span class="contact__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.8.6 2.8.7A2 2 0 0 1 22 16.9z"/></svg></span><div><b>Telefon (mobil)</b><span>0179 4741210</span></div></a></li>
              <li><span class="contact__ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span><div><b>Standort</b><span>Hamm, Deutschland</span></div></li>
            </ul>
          </div>
          <form class="contact__form reveal" id="form">
            <h3>Schreib mir eine Nachricht</h3>
            <p class="contact__formlead">Ich melde mich in der Regel innerhalb von 24 Stunden. Lieber direkt? <a href="tel:+491794741210" style="color:var(--gold-bright);font-weight:600">Ruf mich an</a>.</p>
            <div class="field"><label for="name">Name</label><input id="name" name="name" type="text" autocomplete="name" placeholder="Dein Name" required></div>
            <div class="field"><label for="email">E-Mail</label><input id="email" name="email" type="email" autocomplete="email" placeholder="deine@email.de" required></div>
            <div class="field"><label for="branche">Branche</label>
              <select id="branche" name="branche">
                <option value="" disabled selected>Wähle deine Branche</option>
                <option>Friseur / Beauty</option>
                <option>Elektriker / Handwerk</option>
                <option>Restaurant / Café / Bar</option>
                <option>Andere</option>
              </select>
            </div>
            <div class="field"><label for="msg">Nachricht</label><textarea id="msg" name="message" rows="4" placeholder="Erzähl mir kurz von deinem Projekt…"></textarea></div>
            <button type="submit" class="btn btn--primary btn--lg btn--block">Nachricht senden
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4z"/></svg>
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <!-- ===== FOOTER ===== -->

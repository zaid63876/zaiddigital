  <!-- Website-Finder Dialog -->
  <div class="finder" id="finder" aria-hidden="true">
    <div class="finder__overlay" data-close></div>
    <div class="finder__box" role="dialog" aria-modal="true" aria-label="Website-Finder">
      <button class="finder__close" data-close aria-label="Schließen">&times;</button>
      <div class="finder__progress"><span id="finderBar"></span></div>
      <div class="finder__body" id="finderBody"></div>
    </div>
  </div>

  <!-- Mobile sticky action bar -->
  <div class="mobilebar">
    <a href="tel:+491794741210" class="mobilebar__call">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2 4.2 2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.8.6 2.8.7A2 2 0 0 1 22 16.9z"/></svg>
      Anrufen
    </a>
    <a href="#kontakt" class="mobilebar__cta">Anfrage senden</a>
  </div>

  <script src="script.js"></script>
  <script src="livereload.js"></script>
</body>
